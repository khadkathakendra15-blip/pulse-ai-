# ── Backend (NestJS) ────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Local dev: file-based SQLite (zero setup). Created by `prisma migrate dev`.
DATABASE_URL="file:./dev.db"
# Production: switch schema.prisma datasource provider to "postgresql" and use e.g.
#   DATABASE_URL=postgresql://pulse:pulse@localhost:5432/pulse?schema=public

# Redis (sessions / cache / queues) — not required for the local run
REDIS_URL=redis://localhost:6379

# Auth — generate a strong secret for anything beyond local dev:  openssl rand -hex 32
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=7d

# AI engine (FastAPI) base URL — docker-compose service name in compose, localhost otherwise
AI_ENGINE_URL=http://localhost:8000
