# ── Backend (NestJS) ────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Postgres connection string. On Railway, add a Postgres plugin and it injects
# DATABASE_URL automatically. Locally, use a hosted (Neon/Supabase) or local URL.
DATABASE_URL=postgresql://user:pass@host:5432/pulse

# Redis (sessions / cache / queues) — not required yet
REDIS_URL=redis://localhost:6379

# Auth — generate a strong secret for anything beyond local dev:  openssl rand -hex 32
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=7d

# AI engine (FastAPI) base URL — docker-compose service name in compose, localhost otherwise
AI_ENGINE_URL=http://localhost:8000
