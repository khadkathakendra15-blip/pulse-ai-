# ── AI engine (FastAPI) ─────────────────────────────────────────────
# LLM provider for Pulse Coach. Without a key the coach still serves
# deterministic bilingual replies for the quick-prompt chips.
PULSE_LLM_PROVIDER=anthropic
PULSE_LLM_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=

# Alternate providers (only if PULSE_LLM_PROVIDER is changed and wired in llm.py)
# OPENAI_API_KEY=
# GEMINI_API_KEY=
